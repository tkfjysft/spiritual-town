---
// 1. スタイルと動くマップコンポーネントを読み込み
import '../styles/global.css';
import SpiritualTown from '../components/SpiritualTown.tsx';

// 2. 分割したJSONデータをそれぞれ読み込み
import navData from '../data/navigation.json';
import heroData from '../data/hero.json';
import categoriesData from '../data/categories.json';
import featuredData from '../data/featuredSpots.json';
import newsDate from '../data/news.json';
import applicationData from '../data/application.json';
import Header from '../components/Header.astro';
import { DESCRIPTION } from '../data/site';
---

<html lang="ja" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={ DESCRIPTION }>
        <title>{heroData.siteTitle}</title>
    </head>
    <body class="bg-slate-50 antialiased pt-16">
        
        <!-- グローバルナビゲーション（ヘッダー） -->
        <Header />

        <main class="mx-auto py-8">
            
            <!-- ヘッダー・メインビジュアル部分 -->
            <header class="text-center mb-16">
                <h1>
					<img 
					src={heroData.titleImage} 
					alt={heroData.title}
					fetchpriority="high"
					width="542" 
					height="600" 
					class="w-[70vw] md:w-120 mx-auto mb-4"
					fetchpriority="high" 
					loading="eager"
					/>
                </h1>
                <p class="text-lg md:text-xl text-slate-500 font-medium tracking-wide">
                    			{heroData.subtitle.split('、')[0]}、
			<span class="block sm:inline">
				{heroData.subtitle.split('、')[1]}
			</span>
                </p>
            </header>

            <!-- イントロダクション（説明文）部分 -->
            <section class="bg-white border border-slate-100/80 shadow-md shadow-slate-100 p-8 rounded-3xl text-center leading-relaxed text-slate-600 mb-20 relative mx-[2vw] md:mx-10 lg:mx-auto lg:max-w-3xl">
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-teal-50 text-teal-700 text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest">Welcome</div>
                <p class="text-base md:text-lg text-left">{heroData.introText}</p>
            </section>

            <!-- メイン機能（街のマップ）部分 -->
            <section id="map" class="mb-24 scroll-mt-24 mx-[2vw] md:mx-10 lg:mx-20">
                <div class="bg-white p-4 rounded-3xl border border-slate-100 shadow-sm">
                    <SpiritualTown client:load />
                </div>
            </section>



            <!-- 新着 -->
