<section id="featured" class="mb-24 py-16 w-full bg-white">
    <div class="text-center mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-amber-900 mb-3">
            {newsDate.title}
        </h2>
        <p class="text-sm text-slate-600 tracking-wide">{newsDate.subtitle}</p>
    </div>
    
<div class="grid grid-cols-1 md:grid-cols-1 gap-8 max-w-4xl mx-auto px-6">
    {newsDate.items.map((spot) => (
        <div class="bg-white rounded-3xl border border-gray-100 shadow-[0_4px_20px_-5px_rgba(0,0,0,0.1)] flex flex-col group transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
            <div class="h-3 bg-gradient-to-r from-pink-200 via-sky-200 to-amber-200 rounded-t-3xl"></div>
            
            <div class="p-8 flex-1 flex flex-col md:flex-row gap-8">
                
                <div class="web-thum md:w-1/3 shrink-0">
                    <a href={spot.url} class="block h-full hover:opacity-80 transition-opacity" target="_blank" rel="noopener noreferrer">
<img 
    src={spot.image && spot.image.trim() !== "" ? spot.image : "/thum/nothum.avif"} 
    alt={spot.name}
    loading="eager" 
    fetchpriority="high"
    class="w-full h-full aspect-[4/3] object-cover rounded-2xl" 
/>
                    </a>
                </div>

                <div class="web-detail md:w-2/3 flex flex-col">
                    <span class="text-[11px] font-bold text-sky-600 uppercase tracking-widest mb-3 block bg-sky-50 px-2 py-1 rounded-full w-fit">
                        {spot.date}
                    </span>
                    <h3 class="text-xl font-bold text-amber-900 mb-4">
                        {spot.name}
                    </h3>
                    <p class="text-slate-600 text-sm leading-relaxed mb-8 flex-1">
                        {spot.description}
                    </p>
                    
                    <div class="flex items-center justify-between pt-6 border-t border-amber-50 gap-2">
                        <a href={spot.url} class="text-xs font-bold bg-amber-200 text-amber-900 px-4 py-2 rounded-full hover:bg-amber-300 transition-all duration-200 shadow-sm whitespace-nowrap" target="_blank" rel="noopener noreferrer">
                            詳細を見る
                        </a>
                    </div>
                </div>
            </div>
        </div>
    ))}
</div>
</section>







            <!-- 街の案内所（カテゴリ一覧カード）部分 -->
            <section id="categories" class="mb-24 scroll-mt-24 mx-[2vw] md:mx-10 lg:mx-20">
                <div class="text-center mb-12">
                    <h2 class="text-2xl md:text-3xl font-bold text-slate-800 mb-3">
                        {categoriesData.title}
                    </h2>
                    <p class="text-sm text-slate-500">目的のジャンルが決まっている方はこちらからどうぞ</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    {categoriesData.items.map((category) => (
                        <div class="bg-white border border-slate-100 p-6 rounded-2xl shadow-sm hover:shadow-md transition-all duration-200">
                            <div class="text-4xl mb-4">{category.icon}</div>
                            <h3 class="text-xl font-bold text-slate-800 mb-2">
                                {category.name}
                            </h3>
                            <p class="text-slate-600 text-sm leading-relaxed mb-4">
                                {category.description}
                            </p>
                            <a href={`/category/${category.id}`} class="inline-flex items-center text-sm font-semibold text-teal-800 hover:text-teal-700 transition-colors">
                                このエリアを散策する →
                            </a>
                        </div>
                    ))}
                </div>
            </section>



<section class="py-16 px-6 mt-12 bg-white rounded-3xl border border-stone-200 shadow-sm mx-[2vw] md:mx-10 lg:mx-20">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-stone-800 mb-4 tracking-tight">
      {applicationData.title}
    </h2>
    <p class="text-stone-600 mb-10 text-lg">
      {applicationData.description}
    </p>

    <ul class="flex flex-col md:flex-row justify-center gap-6 mb-12">
      {applicationData.steps.map((step, index) => (
        <li class="flex items-center justify-center gap-2">
          <span class="flex items-center justify-center w-8 h-8 rounded-full bg-amber-100 text-amber-700 font-bold">
            {index + 1}
          </span>
          <span class="text-stone-700 font-medium">{step}</span>
        </li>
      ))}
    </ul>

    <a 
      href={applicationData.button.link} target="_blank" rel="noopener noreferrer"
      class="inline-block px-8 py-4 bg-amber-200 text-amber-900 font-bold rounded-full hover:bg-amber-300 transition-all shadow-md hover:shadow-lg"
    >
      {applicationData.button.text}
    </a>
  </div>
</section>

    <a 
      href={navData.links[5].url} target="_blank" rel="noopener noreferrer"
      class="flex items-center justify-center px-8 py-4 my-10 bg-pink-100 text-amber-900 font-bold rounded-full hover:bg-amber-300 transition-all shadow-md hover:shadow-lg mx-[2vw] md:mx-10 lg:mx-20"
    >
      {navData.links[5].label}
    </a>


            <!-- フッター部分 -->
            <footer class="text-center py-8 text-sm text-slate-400 border-t border-slate-200/60">
                <p>{navData.copyright}</p>
            </footer>

        </main>
    </body>
</html>