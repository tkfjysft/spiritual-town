---
// 1. スタイルの読み込みとデータの読み込み
import '../../styles/global.css';

import siteData from '@/data/site.json';
import spotsData from '@/data/common/spots.json';
import Header from '../../components/Header.astro';

export function getStaticPaths() {
  return [
    { params: { id: 'fortune' } },
    { params: { id: 'healing' } },
    { params: { id: 'shop' } },
    { params: { id: 'counseling' } },
    { params: { id: 'meditation' } },
  ];
}

const { id } = Astro.params;
const currentCategory = spotsData[id as keyof typeof spotsData];

// パージ対策を施した背景グラデーションの設定
const bgGradients = {
  fortune: "bg-gradient-to-r from-purple-500 to-indigo-600",
  healing: "bg-gradient-to-r from-emerald-500 to-teal-600",
  shop: "bg-gradient-to-r from-amber-500 to-orange-600",
  counseling: "bg-gradient-to-r from-rose-500 to-pink-600",
  meditation: "bg-gradient-to-r from-sky-500 to-blue-600"
};
const currentBg = bgGradients[id as keyof typeof bgGradients] || "bg-slate-800";
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{currentCategory.title} | {siteData.title}</title>
    </head>
    <body class="bg-slate-50 antialiased pt-16">
        
        <!-- <nav class="fixed top-0 left-0 right-0 h-16 bg-white/80 backdrop-blur-md border-b border-slate-200/60 z-50">
            <div class="max-w-6xl mx-auto h-full px-4 flex items-center justify-between">
                <a href="/" class="text-xl font-bold text-slate-800 tracking-wider hover:opacity-80 transition-opacity">
                    {siteData.title}
                </a>
                <a href="/" class="text-sm font-semibold text-teal-800 hover:text-teal-700 transition-colors">
                    ← 街のマップに戻る
                </a>
            </div>
        </nav> -->
                <Header />

        <div class={`w-full py-24 md:py-32 ${currentBg} text-white text-center px-4 shadow-sm relative overflow-hidden`}>
            <div class="max-w-3xl mx-auto relative z-10">
                <h1 class="text-3xl md:text-5xl font-extrabold tracking-widest mb-4 drop-shadow-sm">
                    {currentCategory.title}
                </h1>
                <p class="text-white/90 text-sm md:text-lg max-w-xl mx-auto leading-relaxed tracking-wide font-medium">
                    {currentCategory.description}
                </p>
            </div>
            <div class="absolute inset-0 bg-black/5 pointer-events-none"></div>
        </div>
        
        
        
        <main class="max-w-4xl mx-auto px-4 py-12">
            <div class="space-y-6">
{currentCategory.spots.map((spot) => (
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6 md:p-8 flex flex-col md:flex-row gap-6 hover:shadow-md transition-shadow duration-200">
        
        <div class="web-thum md:w-[30%] shrink-0">
			 <a 
                    href={spot.url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                >
            <img 
                src={`/thum/${ spot.image && spot.image.trim() !== "" ? spot.image : "/thum/nothum.avif"} `}
                alt={spot.name}
                loading="eager" 
                fetchpriority="high"
                class="w-full aspect-[4/3] object-cover rounded-2xl" 
            />
			</a>
        </div>

        <div class="web-detail md:w-[70%] flex flex-col justify-between">
            <div class="flex-1">
                <h2 class="text-xl font-bold text-slate-800 mb-2">
                    {spot.name}
                </h2>
                <p class="text-slate-500 text-sm leading-relaxed mb-4">
                    {spot.description}
                </p>
                <div class="flex flex-wrap gap-1.5 mb-6">
                    {spot.tags.map((tag) => (
                        <span class="text-xs font-medium bg-slate-100 text-slate-600 px-2.5 py-0.5 rounded-md">
                            #{tag}
                        </span>
                    ))}
                </div>
            </div>
            
            <div class="whitespace-nowrap flex items-center">
                <a 
                    href={spot.url} 
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="w-full md:w-auto text-center px-5 py-3 text-sm font-bold border-1 border-gray-300 text-gray-900 bg-white hover:bg-gray-50 hover:border-gray-600 rounded-xl shadow-sm transition-colors duration-200"
                >
                    公式サイトを訪問する ↗
                </a>
            </div>
        </div>
    </div>
))}
            </div>
        </main>

        <footer class="text-center py-8 text-sm text-slate-400 border-t border-slate-200/60 mt-12">
            <p>{siteData.copyright}</p>
        </footer>
    </body>
</html>