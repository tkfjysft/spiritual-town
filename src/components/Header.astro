---
import * as Icons from 'lucide-astro';
import siteData from '@/data/site.json';
---

<nav class="fixed top-0 left-0 right-0 h-16 md:h-24 min-h-[64px] bg-white/80 backdrop-blur-md border-b border-slate-200/60 z-50">
<div class="max-w-6xl mx-auto h-full px-4 flex items-center justify-between">
    <a href="/" class="flex items-center justify-center h-16 md:h-20 hover:opacity-80 transition-opacity">
                    <img 
                src={siteData.navigation.siteNameImage} 
                alt={siteData.title}
                loading="eager" 
                fetchpriority="high"
                width="1042" 
                height="128" 
                class="w-[45vw] md:w-70 block aspect-[1042/128]" 
            />
        </a>

<div class="hidden lg:flex items-center gap-6">
    {siteData.navigation.links.map((link) => {
        // アイコン名に対応するコンポーネントを動的に取得
        const IconComponent = Icons[link.icon as keyof typeof Icons];
								const isExternal = link.url.startsWith('http');

        
        return (
            <a href={link.url} class="flex items-center gap-1 text-base font-medium text-slate-600 hover:text-teal-800 transition-colors"
                onclick="document.getElementById('drawer').classList.add('translate-x-full')"
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
            >
                {IconComponent && <IconComponent size={18} />}
                {link.label}
            </a>
        );
    })}
</div>

        <button id="menu-btn" class="lg:hidden p-2 text-slate-800" aria-label="メニューを開く">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
        </button>
    </div>
</nav>

    <div id="drawer" class="lg:hidden fixed inset-0 bg-white z-50 transform translate-x-full transition-transform duration-300">
        <div class="p-4 flex justify-end">
            <button id="close-btn" class="p-2 text-slate-800" aria-label="メニューを閉じる">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
        <div class="flex flex-col items-center gap-8 mt-10">
            {siteData.navigation.links.map((link) => {
				        const IconComponent = Icons[link.icon as keyof typeof Icons];
						const isExternal = link.url.startsWith('http');
                return (
<a 
                href={link.url} 
                class="flex items-center gap-2 text-2xl font-medium text-slate-800" 
                onclick="document.getElementById('drawer').classList.add('translate-x-full')"
                target={isExternal ? "_blank" : undefined}
                rel={isExternal ? "noopener noreferrer" : undefined}
            >
                {IconComponent && <IconComponent size={24} />}
                {link.label}
            </a>
        );
    })}
        </div>
    </div>


<script>
    document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const drawer = document.getElementById('drawer');

    // 開く処理
    btn?.addEventListener('click', () => {
        drawer?.classList.remove('translate-x-full');
    });

    // 閉じる処理
    closeBtn?.addEventListener('click', () => {
        drawer?.classList.add('translate-x-full');
    });
    });
</script>